{
  "name": "@rahadiana/opencode-multi-account",
  "version": "1.0.1",
  "description": "Plugin OpenCode untuk manajemen multi-akun API dengan rotasi otomatis saat rate limit tercapai",
  "main": "dist/index.js",
  "type": "module",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "multi-account",
    "rate-limit",
