    "prepublishOnly": "npm run build",
    "test": "npm run typecheck && tsx --test \"src/**/*.test.ts\""
  },
  "author": "rahadiana nugraha <rahadiana@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rahadiana/opencode-multi-account.git"
  },
  "bugs": {
    "url": "https://github.com/rahadiana/opencode-multi-account/issues"
  },
  "homepage": "https://github.com/rahadiana/opencode-multi-account#readme",
  "license": "MIT",
  "devDependencies": {
    "@opencode-ai/plugin": "latest",
    "@types/node": "^25.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.4.0"
  }
}
